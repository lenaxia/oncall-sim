apiVersion: v1
kind: Secret
metadata:
  name: oncall-secrets
type: Opaque
stringData:
  # LiteLLM model string — provider-prefixed
  # Examples: openai/gpt-4o | bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0
  llm-model: "openai/gpt-4o"

  # API key for the LLM backend
  llm-api-key: "YOUR_API_KEY_HERE"

  # Base URL for the LLM endpoint (leave empty to use provider default)
  llm-base-url: "https://ai.thekao.cloud/v1"
