apiVersion: v1
kind: Secret
metadata:
  name: oncall-secrets
type: Opaque
stringData:
  # LiteLLM model string — provider-prefixed
  # Examples: openai/gpt-4o | bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0
  llm-model: "openai/gpt-4o"

  # API key for the LLM backend
  llm-api-key: "YOUR_API_KEY_HERE"

  # Base URL for the LLM endpoint (leave empty to use provider default)
  llm-base-url: "https://ai.thekao.cloud/v1"

  # Shared HMAC secret for proxy token protection.
  # Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
  # Must match the value given to the client container as PROXY_TOKEN_SECRET.
  proxy-token-secret: "CHANGE_ME_generate_with_secrets_token_hex_32"
