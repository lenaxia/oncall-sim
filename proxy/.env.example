# LLM proxy sidecar — environment variables for k8s mode
# Inject these from a Kubernetes Secret (never commit real values)

# LiteLLM model string — provider-prefixed format
# Examples:
#   openai/gpt-4o                                  (OpenAI or LiteLLM proxy)
#   bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0
#   anthropic/claude-3-5-sonnet-20241022
LLM_MODEL=openai/gpt-4o

# API key for the LLM backend (optional if using IAM role for Bedrock)
LLM_API_KEY=

# Custom base URL for the LLM endpoint (e.g. your LiteLLM server)
# Leave empty to use the LiteLLM default for the provider
LLM_BASE_URL=https://ai.thekao.cloud/v1

# Comma-separated allowed CORS origins
# In production limit to the client container's origin
CORS_ORIGINS=http://localhost:3000

# ── Proxy token protection ─────────────────────────────────────────────────────
# Shared secret used to sign short-lived tokens that the client SPA presents on
# every LLM request. Prevents direct bot/script abuse of the proxy endpoint.
#
# Generate a strong value with:  python3 -c "import secrets; print(secrets.token_hex(32))"
#
# Must be set to the same value in both the client container (as PROXY_TOKEN_SECRET)
# and the proxy container. Leave empty to DISABLE token checking (dev only).
PROXY_TOKEN_SECRET=

# Token TTL in seconds (default: 3600 — tokens expire after 1 hour, requiring a page reload)
# PROXY_TOKEN_TTL_SECONDS=3600

# ── Rate limiting ──────────────────────────────────────────────────────────────
# Max LLM requests per IP per minute (default: 20)
# RATE_LIMIT_PER_MINUTE=20
